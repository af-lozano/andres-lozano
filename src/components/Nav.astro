---
interface Props {
  locale: string | undefined;
}

const { locale } = Astro.props;
import { getTranslations } from "../i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

const currentPath = Astro.url.pathname.replace(/^\/[a-z]{2}(\/|$)/, "/");
const t = getTranslations(locale || "es");

const links = [
  { href: "/", label: t["nav.home"] },
  { href: "/experience/", label: t["nav.experience"] },
  { href: "/about/", label: t["nav.about"] },
];
---

<nav>
  <ul>
    {
      links.map((link) => (
        <li class:list={[{ "active-link": currentPath === link.href }]}>
          <a href={getRelativeLocaleUrl(locale || "es", link.href)}>
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
  <div class="underline-anchor"></div>
</nav>
<style>
  ul {
    display: flex;
    flex-direction: row;
    list-style-type: none;
    gap: 1rem;
    padding-inline: 0;
  }
  .active-link {
    anchor-name: --ancla;
  }
  nav {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr auto;
    view-transition-name: navigation;
    padding-inline: 1rem;
    padding-block: 0.25rem;
  }
  a {
    color: inherit;
    text-decoration: none;
  }
  .underline-anchor {
    position: absolute;
    position-anchor: --ancla;
    height: 5px;
    left: anchor(left);
    right: anchor(right);
    bottom: anchor(bottom);
    background: red;
    view-transition-name: anchor;
  }
</style>
